# ==============================================================================
# 🗄️ DATABASE (PostgreSQL)
# ==============================================================================
POSTGRES_USER=postgres
# В примере ставим небезопасный пароль. В .env задай сложный!
POSTGRES_PASSWORD=postgres_dev_password
POSTGRES_DB=car_ads
POSTGRES_PORT=5432

# Строка подключения для SQLAlchemy (внутри Docker используем хост 'db')
# Убедись, что пароль здесь совпадает с POSTGRES_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres:postgres_dev_password@db:5432/car_ads

# ==============================================================================
# 🚀 INFRASTRUCTURE (Redis)
# ==============================================================================
REDIS_PORT=6379

# ==============================================================================
# ⚡ BACKEND API (FastAPI)
# ==============================================================================
API_PORT=8000
# Сгенерируй надежный ключ: openssl rand -hex 32
# Важно: если ключ изменится, все старые JWT токены пользователей перестанут работать
SECRET_KEY=change-me-to-a-secure-random-string

# ==============================================================================
# 🎨 FRONTEND (React/Vite)
# ==============================================================================
FRONTEND_PORT=3000
# Vite требует префикс VITE_ для переменных окружения
VITE_API_URL=http://localhost:8000/api/v1

# ==============================================================================
# 🤖 TELEGRAM BOT
# ==============================================================================
# Получи токен у @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ_example

# ==============================================================================
# 🧠 AI & LLM (Ollama / OpenAI)
# ==============================================================================
# Для локальной Ollama используй 'ollama', для OpenAI - 'sk-...'
LLM_API_KEY=ollama
# Для Ollama внутри Docker используем host.docker.internal
# Для OpenAI используй: https://api.openai.com/v1
LLM_BASE_URL=http://host.docker.internal:11434/v1
# Модель: llama3, llama3.1, gpt-4o-mini и т.д.
LLM_MODEL_NAME=llama3.1